# eShop CODEOWNERS
# Each line is a file pattern followed by one or more owners.
# Later rules take precedence over earlier ones.

# -------------------------------------------------------
# Default: engineering leads own everything not matched below
# -------------------------------------------------------
* @engineering-leads

# -------------------------------------------------------
# Root config files
# -------------------------------------------------------
/*.md @engineering-leads
/*.props @engineering-leads
/*.targets @engineering-leads
/*.slnx @engineering-leads
/*.slnf @engineering-leads
/*.json @engineering-leads
/*.yml @engineering-leads
/*.config @engineering-leads
/*.ts @engineering-leads
/.editorconfig @engineering-leads
/.gitignore @engineering-leads
/.gitattributes @engineering-leads

# -------------------------------------------------------
# Infrastructure / deployment
# -------------------------------------------------------
/infra/ @platform-team

